# ── Secrets & environment files ───────────────────────────────────────────
# .env contains VITE_API_BASE_URL for local dev only.
# In CI the value is injected via --build-arg, never from this file.
.env
.env.*
*.env

# ── Node modules (reinstalled inside image via npm ci) ────────────────────
node_modules/

# ── Previous build output (rebuilt clean inside image) ────────────────────
dist/
dist-ssr/

# ── Editor & OS artifacts ─────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.suo
*.sw?

# ── Git ───────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── CI/CD ─────────────────────────────────────────────────────────────────
.github/

# ── Docker files themselves ───────────────────────────────────────────────
# nginx.conf is intentionally NOT excluded — Stage 2 of the Dockerfile
# does: COPY nginx.conf /etc/nginx/conf.d/default.conf
Dockerfile
.dockerignore
docker-compose*.yml

# ── Logs & test artifacts ─────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
coverage/
.nyc_output/

# ── Docs ──────────────────────────────────────────────────────────────────
README.md
*.md
